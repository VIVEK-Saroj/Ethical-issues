# Database — use PostgreSQL in production (SQLite OK for local dev)
DATABASE_URL=postgresql://user:pass@host/bigmart?sslmode=require
# DATABASE_URL=sqlite:///./bigmart.db

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string

# YOLO model (auto-downloads if not found)
YOLO_MODEL_PATH=yolov8m.pt
YOLO_IMG_SIZE=1280

# Cloudinary (optional — local storage used if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL — added to CORS automatically
FRONTEND_URL=https://your-app.onrender.com
